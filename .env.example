APP_NAME=nova-doc-pipeline
ENVIRONMENT=local
DATABASE_URL=sqlite:///./nova.db

OPENAI_API_KEY=
GOOGLE_API_KEY=

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

PRIMARY_VISION_MODEL=gpt-4o
FALLBACK_VISION_MODEL=gemini-1.5-flash
